# Machine config: aibox (4× NVIDIA A800-SXM4-80GB)
# CFS mount: /mnt/cfs/vffey4/omni3d/
# To onboard: see docs/new-machine-onboarding.md

# ── Conda ──────────────────────────────────────────────────────────
CONDA_INIT=/root/miniforge/etc/profile.d/conda.sh
# CONDA_ENV_* use full paths (no short name registered for these envs)
CONDA_ENV_SERVER=qwen_test      # sglang 0.5.9 (VLM server); /mnt/cfs/vffey4/envs/qwen_test
CONDA_ENV_PIPELINE=vinedresser3d # partcraft.pipeline_v2 + openai; /mnt/cfs/vffey4/envs/vinedresser3d

# ── Checkpoints ────────────────────────────────────────────────────
VLM_CKPT=/mnt/cfs/vffey4/omni3d/ckpt/Qwen3.5-27B
EDIT_CKPT=/mnt/cfs/vffey4/omni3d/ckpt/FLUX.2-klein-9B
TRELLIS_CKPT_ROOT=/mnt/cfs/vffey4/omni3d/ckpt
# load_config() only reads PARTCRAFT_CKPT_ROOT (see partcraft/utils/config.py); keep in sync with TRELLIS_CKPT_ROOT
export PARTCRAFT_CKPT_ROOT="${PARTCRAFT_CKPT_ROOT:-${TRELLIS_CKPT_ROOT}}"

# ── Data I/O ───────────────────────────────────────────────────────
DATA_DIR=/mnt/cfs/vffey4/omni3d/partverse
OUTPUT_ROOT=/mnt/cfs/vffey4/omni3d/partverse/outputs/partverse

# ── Optional tools ─────────────────────────────────────────────────
BLENDER_PATH=/usr/local/bin/blender

# ── Proxy bypass for localhost (squid proxy is set machine-wide) ───
export no_proxy=localhost,127.0.0.1
export NO_PROXY=localhost,127.0.0.1

# ── VLM server tuning (A800 80GB, Qwen3.5-27B ~54GB fp16) ─────────
# mem_fraction_static: fraction of VRAM reserved for model weights
# default 0.5 (40GB) is insufficient; 0.85 (68GB) leaves ~12GB for KV cache
export VLM_MEM_FRAC=0.85

# ── DINOv2 offline weights ──────────────────────────────────────────
PARTCRAFT_DINOV2_WEIGHTS=/mnt/cfs/vffey4/omni3d/ckpt/hub/checkpoints/dinov2_vitl14_reg4_pretrain.pth
