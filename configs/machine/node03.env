# Machine config: node03 (8× NVIDIA A800-80GB PCIe)
# Auto-loaded by hostname match in run_pipeline_v3_shard.sh.
# Override: MACHINE_ENV=configs/machine/node03.env

# ── Conda ──────────────────────────────────────────────────────────
CONDA_INIT=/home/artgen/miniconda3/etc/profile.d/conda.sh
CONDA_ENV_SERVER=qwen_test         # VLM (sglang) + FLUX server
CONDA_ENV_PIPELINE=vinedresser3d   # pipeline_v3 driver

# ── Checkpoints ────────────────────────────────────────────────────
VLM_CKPT=/Node11_nvme/zsn/checkpoints/Qwen3.5-27B
EDIT_CKPT=/Node11_nvme/wjw/checkpoints/FLUX.2-klein-9B
TRELLIS_CKPT_ROOT=/Node11_nvme/wjw/3D_Editing/PartCraft3D/checkpoints

# ── Data I/O ───────────────────────────────────────────────────────
DATA_DIR=/Node11_nvme/wjw/3D_Editing/data/inputs/partverse
OUTPUT_ROOT=/Node11_nvme/wjw/3D_Editing/data/outputs/partverse

# ── Proxy bypass for localhost health checks ───────────────────────
export no_proxy=127.0.0.1,localhost
export NO_PROXY=127.0.0.1,localhost

# ── Attention backend ──────────────────────────────────────────────
# vinedresser3d env on node03 has xformers 0.0.27.post2+cu118 but NOT
# flash_attn. Trellis attention/sparse modules read ATTN_BACKEND and
# accept {xformers, flash_attn, sdpa, naive}.
export ATTN_BACKEND=xformers

# ── CUDA toolkit (FlashInfer JIT) ──────────────────────────────────
# Login-shell profile on node03 sets CUDA_HOME=/usr/local/cuda-12.1, but
# that directory does NOT exist on this host. SGLang (qwen_test env)
# uses flashinfer for sampling kernels which JIT-compile via $CUDA_HOME/
# bin/nvcc; with the stale path the server crashes at first request
# ("/usr/local/cuda-12.1/bin/nvcc: not found"). Force the real toolkit
# present on node03 (CUDA 12.4) and prepend its bin to PATH.
export CUDA_HOME=/usr/local/cuda-12.4
export PATH=/usr/local/cuda-12.4/bin:$PATH

# ── GPU topology (8× A800-80GB) ────────────────────────────────────
VLM_GPUS=0,1,2,3,4,5,6,7
VLM_TP=1
EDIT_GPUS=0,1,2,3,4,5,6,7
STEP4_GPUS=0,1,2,3,4,5,6,7

# ── VLM VRAM ──────────────────────────────────────────────────────
# Qwen3.5-27B weights ≈ 52 GB; default 0.57 (≈45.6 GB on 80 GB A800)
# OOMs at scheduler init.
#  - 0.85 → 68 GB (best when GPU is exclusive; ~16 GB KV cache)
#  - 0.75 → 60 GB (safe when other users hold ~18-20 GB on busy cards;
#                  KV cache shrinks to ~8 GB → keep VLM_MAX_RUNNING low)
# Drop to 0.75 + VLM_MAX_LEN=16384 if a co-tenant returns.
export VLM_MEM_FRAC=0.85

# ── SGLang server-side concurrency cap ────────────────────────────
# With ~17 GB KV cache, ~8 concurrent multimodal requests fit safely.
# Without this cap, gate_text_align fan-out queues hundreds of
# requests, and the client (OpenAI SDK) times out before SGLang ever
# schedules them.  See scripts/tools/launch_local_vlm.sh.
export VLM_MAX_RUNNING=8

# ── SGLang watchdog ───────────────────────────────────────────────
# SGLang 0.5.6 has a multimodal shm race that can crash the server
# scheduler after several hours of load (mm_utils.__setstate__ →
# SharedMemory(name='/psm_xxx') → FileNotFoundError).  Auto-restart
# up to 5 times if the server has been healthy for ≥ 120 s.  The
# pipeline driver doesn't health-check post-startup, so without this
# a single crash silently consumes 1/N of the request load forever.
export VLM_AUTO_RESTART=5
export VLM_MIN_HEALTHY_S=120
