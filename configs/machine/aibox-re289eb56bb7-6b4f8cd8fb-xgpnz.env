# Machine config: aibox-re289eb56bb7 (4× NVIDIA A800-SXM4-80GB)
# CFS mount: /mnt/cfs/dev_hs/omni3d/  (formerly /mnt/cfs/vffey4/omni3d/)
# Sister of aibox-rd3996bf91f9-...env — same conda envs, same data tree, only
# the CFS mount root changed (vffey4 → dev_hs).

# ── Conda ──────────────────────────────────────────────────────────
CONDA_INIT=/root/miniforge/etc/profile.d/conda.sh
CONDA_ENV_SERVER=qwen_test       # sglang VLM server; /mnt/cfs/dev_hs/envs/qwen_test
CONDA_ENV_PIPELINE=vinedresser3d # partcraft.pipeline_v3 driver; /mnt/cfs/dev_hs/envs/vinedresser3d

# ── Checkpoints ────────────────────────────────────────────────────
VLM_CKPT=/mnt/cfs/dev_hs/omni3d/ckpt/Qwen3.5-27B
EDIT_CKPT=/mnt/cfs/dev_hs/omni3d/ckpt/FLUX.2-klein-9B
TRELLIS_CKPT_ROOT=/mnt/cfs/dev_hs/omni3d/ckpt
# load_config() only reads PARTCRAFT_CKPT_ROOT (see partcraft/utils/config.py); keep in sync with TRELLIS_CKPT_ROOT
export PARTCRAFT_CKPT_ROOT="${PARTCRAFT_CKPT_ROOT:-${TRELLIS_CKPT_ROOT}}"

# ── Data I/O ───────────────────────────────────────────────────────
DATA_DIR=/mnt/cfs/dev_hs/omni3d/partverse
OUTPUT_ROOT=/mnt/cfs/dev_hs/omni3d/partverse/outputs/partverse

# ── Optional tools ─────────────────────────────────────────────────
BLENDER_PATH=/usr/local/bin/blender

# ── Proxy bypass for localhost (squid proxy is set machine-wide) ───
export no_proxy=localhost,127.0.0.1
export NO_PROXY=localhost,127.0.0.1

# ── VLM server tuning (A800 80GB, Qwen3.5-27B ~54GB fp16) ─────────
# 0.85 ≈ 68 GB for weights, leaves ~12 GB KV cache.
export VLM_MEM_FRAC=0.85

# ── CUDA toolkit for FlashInfer JIT in the VLM server env ──────────
# qwen_test (sglang) doesn't ship nvcc; launch_local_vlm.sh aborts with
# "no usable nvcc found". The sister env vinedresser3d bundles CUDA 12.4
# toolkit (nvcc + includes/libs), and sglang links against cu12.x at
# runtime, so reusing this CUDA_HOME is safe for FlashInfer kernel JIT.
export CUDA_HOME=/mnt/cfs/dev_hs/envs/vinedresser3d

# ── DINOv2 offline weights ──────────────────────────────────────────
# MUST be exported so the TRELLIS image pipeline worker (Python child of the
# pipeline driver) sees it. Without export, dinov2_hub.py falls back to the
# default torch-hub path, finds no .pth, and retries urlretrieve() against
# dl.fbaipublicfiles.com — which SSL-fails behind the bypassed proxy.
export PARTCRAFT_DINOV2_WEIGHTS=/mnt/cfs/dev_hs/omni3d/ckpt/hub/checkpoints/dinov2_vitl14_reg4_pretrain.pth

# ── Offline CLIP for TRELLIS text pipeline ─────────────────────────
# trellis_text_to_3d.py loads CLIPTextModel("openai/clip-vit-large-patch14");
# the shard runner unsets all HTTP proxies (localhost-VLM safety), so HF is
# unreachable from workers. _resolve_clip_pretrained_id() picks up this env
# var and loads the model offline. Downloaded once via squid proxy.
export PARTCRAFT_CLIP_MODEL_DIR=/mnt/cfs/dev_hs/omni3d/ckpt/clip-vit-large-patch14
# Belt-and-suspenders: also force offline mode for HF / transformers inside
# the pipeline processes. Prevents any stray .from_pretrained(hub_id) call
# from stalling on retries when the proxy is unset.
export TRANSFORMERS_OFFLINE=1
export HF_HUB_OFFLINE=1
