# Machine config: wm1A800 (4× NVIDIA A800-SXM4-80GB)
# Storage: /mnt/cfs/vffey4 (ckpts, read-only) + /mnt/pfs/ca41bi (data + outputs)
# NOTE: /mnt/cfs/vffey4 已满 99% — 数据与输出均使用 /mnt/pfs/ca41bi/omni3d/partverse
# Used by: scripts/tools/run_shard_batch_pipeline.sh
# Auto-loaded by hostname match; override: MACHINE_ENV=configs/machine/wm1A800.env

# ── Conda ──────────────────────────────────────────────────────────
CONDA_INIT=/root/miniforge/etc/profile.d/conda.sh
CONDA_ENV_SERVER=qwen_test        # env for VLM + image-edit servers
CONDA_ENV_PIPELINE=vinedresser3d  # env for run_pipeline.py

# ── Checkpoints (vffey4, read-only) ────────────────────────────────
VLM_CKPT=/mnt/cfs/vffey4/3dedit/ckpts/Qwen3.5-27B
EDIT_CKPT=/mnt/cfs/vffey4/3dedit/ckpts/FLUX.2-klein-9B
TRELLIS_CKPT_ROOT=/mnt/cfs/vffey4/3dedit/ckpts

# ── Data I/O (pfs, 201T 总量 / 135T 可用) ──────────────────────────
# PFS 已有 images/mesh/slat for shard 04 & 09
DATA_DIR=/mnt/pfs/ca41bi/omni3d/partverse
OUTPUT_ROOT=/mnt/pfs/ca41bi/omni3d/partverse

# ── Proxy bypass (系统有 http_proxy，需绕过 localhost 健康检查) ─────
export no_proxy=127.0.0.1,localhost
export NO_PROXY=127.0.0.1,localhost

# ── Attention backend ───────────────────────────────────────────────
ATTN_BACKEND=flash_attn

# ── GPU topology (4× A800-SXM4-80GB, 80GB each) ────────────────────
# Qwen3.5-27B ~54GB BF16 → fits single A800 (80GB), TP=1 sufficient
# Step1/2: 4 VLM instances (TP=1), GPUs 0-3, ports 8003-8006
# Step3:   4 FLUX edit servers,    GPUs 0-3, ports 8004-8007
# Step4:   TRELLIS on all 4 GPUs
VLM_GPUS=0,1,2,3
VLM_TP=1
EDIT_GPUS=0,1,2,3
STEP4_GPUS=0,1,2,3
