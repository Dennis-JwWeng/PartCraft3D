# Machine config: node37 (8x A800 80GB PCIe)
# Used by: scripts/tools/run_shard_batch_pipeline.sh
# To add a new machine: copy this file to <hostname>.env and edit paths.
#
# NOTE: Conda base is /home/artgen/anaconda3 (anaconda3), but pipeline
# envs (qwen_test, vinedresser3d) live under /Node11_nvme/artgen/.miniconda3/envs/
# which is registered via `conda config --append envs_dirs`.

# ── Conda ──────────────────────────────────────────────────────────
CONDA_INIT=/home/artgen/anaconda3/etc/profile.d/conda.sh
CONDA_ENV_SERVER=qwen_test          # env for VLM + image-edit servers
CONDA_ENV_PIPELINE=vinedresser3d    # env for run_pipeline.py

# ── Checkpoints ────────────────────────────────────────────────────
VLM_CKPT=/Node11_nvme/zsn/checkpoints/Qwen3.5-27B
EDIT_CKPT=/Node11_nvme/wjw/checkpoints/FLUX.2-klein-9B
TRELLIS_CKPT_ROOT=/Node11_nvme/wjw/3D_Editing/PartCraft3D/checkpoints

# ── Data I/O ───────────────────────────────────────────────────────
DATA_DIR=/Node11_nvme/wjw/3D_Editing/data/inputs/partverse
OUTPUT_ROOT=/Node11_nvme/wjw/3D_Editing/data/outputs

# ── Attention backend ──────────────────────────────────────────────
ATTN_BACKEND=xformers               # no flash_attn on this machine

# ── GPU topology (PCIe, no NVLink) ────────────────────────────────
# All 8x A800 80GB PCIe — no NVLink pairs; avoid VLM TP > 1.
# Bus layout: GPU 0-3 on one PCIe root, GPU 4-7 on another.

# ── Optional tools ─────────────────────────────────────────────────
BLENDER_PATH=/Node11_nvme/artgen/lac/.tools/blender-4.2.0-linux-x64/blender
