# 本机模板：`data/`、`outputs/` 为仓库根下软链时使用。
# 用法任选其一：
#   cp configs/machine/local_symlink.env.example configs/machine/$(hostname).env
#   # 编辑下面路径后运行 shard 脚本
# 或单次：
#   MACHINE_ENV=configs/machine/local_symlink.env.example bash scripts/tools/run_pipeline_v2_shard.sh ...

# ── Conda ──────────────────────────────────────────────────────────
CONDA_INIT=/root/miniconda3/etc/profile.d/conda.sh
CONDA_ENV_SERVER=pipeline_server
CONDA_ENV_PIPELINE=vinedresser3d

# ── Checkpoints（改成你本机绝对路径）──────────────────────────────
VLM_CKPT=/path/to/Qwen3.5-27B
EDIT_CKPT=/path/to/FLUX.2-klein-9B
# 与 configs/pipeline_v2_local_symlink.yaml 中 ckpt_root 指向同一棵树时，与仓库内 checkpoints/ 一致即可
TRELLIS_CKPT_ROOT=/path/to/PartCraft3D/checkpoints

# ── Data I/O（与软链目标一致，便于 setup_* 脚本与人工核对）────────
# 若 data → /fast/partverse，则 DATA_DIR=/fast/partverse
DATA_DIR=/path/to/real/data/partverse
OUTPUT_DIR=/path/to/real/outputs/partverse
# 兼容 H200.env 命名（部分脚本读 OUTPUT_ROOT）
OUTPUT_ROOT=${OUTPUT_DIR}

# ── GPU（可选，shard 脚本主要读 yaml pipeline.gpus）───────────────
VLM_GPUS="${VLM_GPUS:-0}"
EDIT_GPUS="${EDIT_GPUS:-0}"
STEP4_GPUS="${STEP4_GPUS:-0}"

# ── Optional ───────────────────────────────────────────────────────
BLENDER_PATH=/usr/local/bin/blender
ATTN_BACKEND=flash_attn
