# Machine config: H200 (8× NVIDIA L20X 48GB)
# Used by: scripts/tools/run_shard_batch_pipeline.sh
# To add a new machine: copy this file to <hostname>.env and edit paths.

# ── Conda ──────────────────────────────────────────────────────────
CONDA_INIT=/root/miniconda3/etc/profile.d/conda.sh
CONDA_ENV_SERVER=pipeline_server    # env for VLM + image-edit servers
CONDA_ENV_PIPELINE=vinedresser3d   # env for run_pipeline.py

# ── Checkpoints ────────────────────────────────────────────────────
VLM_CKPT=/mnt/zsn/ckpts/Qwen3.5-27B
EDIT_CKPT=/mnt/zsn/ckpts/FLUX.2-klein-9B
TRELLIS_CKPT_ROOT=/root/workspace/PartCraft3D/checkpoints

# ── Data I/O ───────────────────────────────────────────────────────
DATA_DIR=/mnt/zsn/data/partverse
OUTPUT_ROOT=/mnt/zsn/data/partverse/outputs/partverse

# ── GPU 分组 ────────────────────────────────────────────────────────
# L20X 48GB：TP=1，每卡一个 VLM 实例 → 8 实例并行
# Step1/2: 8× VLM (TP=1)，端口 8003-8010
# Step3  : 8× FLUX edit server，每卡一个，端口 8004-8011
# Step4  : TRELLIS 用全部 8 GPU
VLM_GPUS="${VLM_GPUS:-0,1,2,3,4,5,6,7}"
VLM_TP="${VLM_TP:-1}"
EDIT_GPUS="${EDIT_GPUS:-0,1,2,3,4,5,6,7}"
STEP4_GPUS="${STEP4_GPUS:-0,1,2,3,4,5,6,7}"

# ── Optional tools ─────────────────────────────────────────────────
BLENDER_PATH=/usr/local/bin/blender

# ── Input data roots ────────────────────────────────────────────────────────
# Mesh and image NPZ are under inputs/ (not directly under DATA_DIR).
# Mirror these in pipeline_v2_shard*.yaml data.mesh_root / data.images_root.
MESH_ROOT=${DATA_DIR}/inputs/mesh
IMAGES_ROOT=${DATA_DIR}/inputs/images
